rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Staff-only access — custom claim set server-side via Admin SDK.
    function isStaff() {
      return request.auth != null && request.auth.token.staff == true;
    }

    // Admin-only access — custom claim set server-side via Admin SDK.
    // Admin accounts also carry the staff claim.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ── Menu sections ─────────────────────────────────────────────────────────
    // Public read for the customer web app.
    // Staff can update availability fields only.
    match /menuSections/{doc} {
      allow read: if true;
      allow update: if isStaff()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['availability']);
      allow create, delete: if false;
    }

    // ── Sauces ────────────────────────────────────────────────────────────────
    // Public read for the customer web app.
    // Staff can toggle the available flag only.
    match /sauces/{doc} {
      allow read: if true;
      allow update: if isStaff()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['available']);
      allow create, delete: if false;
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    // All order creation is handled exclusively by Firebase Functions (Admin SDK),
    // which bypasses these rules. The browser can never write directly to orders.
    //
    // Staff can read all orders and update orderStatus.
    match /orders/{orderId} {
      allow create: if false;

      // Staff and admin can read orders. Admin status changes, refunds and any
      // sensitive field writes go through callable Functions (Admin SDK), which
      // bypass these rules. Direct client writes are limited to orderStatus.
      allow read: if isStaff() || isAdmin();

      allow update: if isStaff()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['orderStatus']);

      allow delete: if false;
    }

    // ── Order counters ──────────────────────────────────────────────────────
    // Daily order-number counters. Written only by Functions (Admin SDK).
    match /orderCounters/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Audit logs ──────────────────────────────────────────────────────────
    // Written by admin callable Functions (Admin SDK). Admin can read.
    match /auditLogs/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Store settings ────────────────────────────────────────────────────────
    // Public read for operation hours (order gating on the web app).
    // Staff can update the operationHours document only.
    match /storeSettings/{doc} {
      allow read: if true;
      allow create: if doc == "operationHours"
                    && !exists(/databases/$(database)/documents/storeSettings/operationHours);
      allow update: if isStaff()
                    && doc == "operationHours"
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['timezone', 'days', 'updatedAt']);
      allow delete: if false;
    }

    // ── Failed payments ───────────────────────────────────────────────────────
    // Written by backend Functions only. Never accessible from the browser.
    match /failedPayments/{doc} {
      allow read, write: if false;
    }

    // ── Catch-all: deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
